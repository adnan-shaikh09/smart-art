# =============================================
# Smart Art - Environment Configuration
# Copy this file to .env and fill in values
# =============================================

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=smartart_db
MYSQL_USER=smartart_user
MYSQL_PASSWORD=your_db_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRE=7d

# App Configuration
NODE_ENV=production
PORT=5000

# SMTP Email Configuration (for admin notifications)
# For Gmail: enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=Smart Art Website
SMTP_FROM_EMAIL=your_gmail@gmail.com
# Admin notification email (where enquiry emails will be sent)
ADMIN_NOTIFY_EMAIL=atik@smartart.in
